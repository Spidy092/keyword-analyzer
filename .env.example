# ─── Database ───
DATABASE_URL=postgresql://keyword_user:keyword_pass@localhost:5432/keyword_analyzer
DB_HOST=localhost
DB_PORT=5432
DB_NAME=keyword_analyzer
DB_USER=keyword_user
DB_PASSWORD=keyword_pass

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── API Keys (Free Tiers) ───
SERPER_API_KEY=          # serper.dev - 2500 free searches/day
GOOGLE_CSE_API_KEY=      # Google Custom Search - 100/day free
GOOGLE_CSE_CX=           # Google CSE Engine ID
OPENPAGERANK_API_KEY=    # openpagerank.com - 33k/day free

# ─── Server ───
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── Alerts ───
ALERT_WEBHOOK_URL=       # Telegram/Discord webhook for alerts
CHECK_INTERVAL=86400     # Check rankings every 24 hours (seconds)
